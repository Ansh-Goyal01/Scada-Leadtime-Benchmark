# ── Virtual environment ───────────────────────────────────────────────────────
venv/
.venv/

# ── Python cache ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ── Data — never push raw or processed data ───────────────────────────────────
data/raw/
data/processed/

# ── ONGC Excel files — too large, potentially sensitive ──────────────────────
*.xlsx
*.xls

# ── Results — figures and tables regenerated by notebooks ────────────────────
results/figures/
results/tables/

# ── Trained model weights ────────────────────────────────────────────────────
*.pt
*.pth
*.pkl
*.joblib

# ── OS files ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor ───────────────────────────────────────────────────────────────────
.vscode/
.claude/